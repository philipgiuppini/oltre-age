# OltreAge — variabili d'ambiente Supabase
# Copia questo file in ".env.local" e compila con le chiavi del TUO progetto.
# .env.local è in .gitignore: le chiavi NON finiscono su GitHub.
#
# Dove trovarle: Supabase → Project Settings → API
#   - Project URL            → NEXT_PUBLIC_SUPABASE_URL
#   - anon / public key      → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   - service_role key       → SUPABASE_SERVICE_ROLE_KEY  (SEGRETO: mai lato client, mai su git)
#
# Senza queste variabili l'app gira in "demo mode" con dati locali (localStorage).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo lato server (route /api). Necessaria perché l'admin possa creare
# account di altri utenti (residenti/collaboratori/personale).
SUPABASE_SERVICE_ROLE_KEY=
